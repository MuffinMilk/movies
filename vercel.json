{
  "rewrites": [
    {
      "source": "/api/tmdb/:path*",
      "destination": "https://api.themoviedb.org/3/:path*"
    },
    {
      "source": "/api/tmdb-image/:path*",
      "destination": "https://image.tmdb.org/t/p/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
